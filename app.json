{
  "expo": {
    "name": "Sacred Design",
    "slug": "sacred-design",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/72057605-fb00-4601-8fac-ab7091e359b9.jpeg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/72057605-fb00-4601-8fac-ab7091e359b9.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#F6F1E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "icon": "./assets/images/72057605-fb00-4601-8fac-ab7091e359b9.jpeg",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/72057605-fb00-4601-8fac-ab7091e359b9.jpeg",
        "backgroundColor": "#F6F1E8"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/72057605-fb00-4601-8fac-ab7091e359b9.jpeg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "sacreddesign",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://rxv2r6bszrawnrpuzqt5kh3zhd9kv48u.app.specular.dev"
    }
  }
}