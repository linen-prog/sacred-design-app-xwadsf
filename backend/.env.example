# Apple OAuth configuration
APPLE_PRIVATE_KEY=

# Google OAuth configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=

# Test authentication - SECURITY WARNING
# ⚠️  TEST_AUTH_ENABLED enables the POST /api/test-register-token endpoint
# This allows registering bearer tokens that authenticate as any user with no credentials
# NEVER set this to 'true' in production, staging, or any non-test environment
# Only set to 'true' in local development and CI/CD test runs
# Default: unset (disabled)
TEST_AUTH_ENABLED=
